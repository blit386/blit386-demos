{
  "name": "blit-tech-demos",
  "private": true,
  "type": "module",
  "description": "Interactive demos for Blit-Tech, a palette-first WebGPU retro engine for TypeScript.",
  "author": "Václav Vančura",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/vancura/blit-tech-demos.git"
  },
  "homepage": "https://vancura.dev",
  "keywords": [
    "blit-tech",
    "webgpu",
    "javascript",
    "demos",
    "examples",
    "game-engine",
    "retro",
    "pixel-art",
    "2d-game",
    "2d-demo",
    "sprite",
    "canvas",
    "fantasy-console"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:watch": "pnpm --filter blit-tech build && concurrently -n \"lib,demos\" -c \"blue,green\" \"pnpm --filter blit-tech build --watch\" \"pnpm dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,yml,yaml}\"",
    "format:check": "biome check . && prettier --check \"**/*.{md,mdx,yml,yaml}\"",
    "format:biome": "biome format --write .",
    "format:prettier": "prettier --write \"**/*.{md,mdx,yml,yaml}\"",
    "spellcheck": "cspell \"src/**/*.{js,md,mdx}\" \"docs/**/*.{md,mdx}\" \"README.md\" --no-progress",
    "preflight": "pnpm format:check && pnpm lint && pnpm spellcheck && pnpm knip",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "clean": "rm -rf dist node_modules/.vite",
    "prepare": "husky",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "vite-node": "^5.2.0",
      "esbuild": "^0.25.0"
    }
  },
  "dependencies": {
    "blit-tech": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@eslint/js": "^9.39.2",
    "concurrently": "^9.1.0",
    "cspell": "^9.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-perfectionist": "^5.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "knip": "^5.56.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "vite": "^7.2.7",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
