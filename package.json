{
  "name": "blit386-demos",
  "private": true,
  "type": "module",
  "description": "Interactive demos for BLIT386, a palette-first WebGPU retro engine for TypeScript.",
  "author": {
    "name": "Václav Vančura",
    "url": "https://github.com/vancura"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blit386/blit386-demos.git"
  },
  "homepage": "https://demos.blit386.dev",
  "keywords": [
    "blit386",
    "webgpu",
    "javascript",
    "demos",
    "examples",
    "game-engine",
    "retro",
    "pixel-art",
    "2d-game",
    "2d-demo",
    "sprite",
    "canvas",
    "fantasy-console"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:watch": "pnpm --filter blit386 run build && concurrently -n \"lib,demos\" -c \"blue,green\" \"pnpm --filter blit386 run build --watch\" \"pnpm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "format:check": "biome check . && prettier --check \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "format:biome": "biome format --write .",
    "format:prettier": "prettier --write \"**/*.{md,mdx,mdc,yml,yaml}\"",
    "spellcheck": "cspell \"src/**/*.{js,md,mdx,mdc}\" \"docs/**/*.{md,mdx,mdc}\" \"README.md\" --no-progress",
    "docs:links": "node scripts/check-markdown-links.mjs",
    "generate:audio-loops": "node scripts/generate-audio-loops.mjs",
    "preflight": "pnpm run format:check && pnpm run lint && pnpm run spellcheck && pnpm run knip && pnpm run docs:links && pnpm run build",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "clean": "rm -rf dist node_modules/.vite",
    "prepare": "husky",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix",
    "security:mcp-preflight": "node ../blit386/scripts/security/mcp-preflight.mjs"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "yaml@>=2.0.0 <2.8.3": "^2.8.3",
      "undici@>=7.0.0 <7.28.0": "^7.28.0",
      "js-yaml@>=4.0.0 <4.2.0": "^4.2.0",
      "shell-quote@<1.8.4": "^1.8.4"
    }
  },
  "dependencies": {
    "blit386": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@shikijs/twoslash": "^4.3.1",
    "autoprefixer": "^10.5.4",
    "concurrently": "^9.1.0",
    "cspell": "^10.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^16.4.0",
    "markdown-link-check": "^3.14.2",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.7.4",
    "shiki": "^4.3.1",
    "typescript": "~5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
